<Window x:Class="YourMusicDepotApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Icon="pack://application:,,,/YourMusicDepotApp;component/Icons/YTreble.png"
        xmlns:views="clr-namespace:YourMusicDepotApp.Views"
        Title="YourMusicDepot" Height="1050" Width="1300">

    <Window.Resources>
        <!-- Button Style -->
        <Style x:Key="SidebarButton" TargetType="Button">
            <Setter Property="Background" Value="#27F1C1"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="Gray" Direction="320" ShadowDepth="5" BlurRadius="5" Opacity="0.5"/>
                </Setter.Value>
            </Setter>
            <!-- Visual States for interactive feedback -->
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#35F1C1"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>


        <UniformGrid Grid.Column="0" Rows="4" Background="#27F1C1">
            <Button Style="{StaticResource SidebarButton}" Click="Instructors_Click">
                <StackPanel Orientation="Horizontal">
                    <Image Source="pack://application:,,,/YourMusicDepotApp;component/Icons/instructors.png" Width="48" Height="48"/>
                    <TextBlock Text="Instructors" Foreground="Black" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <Button Style="{StaticResource SidebarButton}" Click="Students_Click">
                    <StackPanel Orientation="Horizontal">
                    <Image Source="pack://application:,,,/YourMusicDepotApp;component/Icons/students.png" Width="48" Height="48"/>
                    <TextBlock Text="Students" Foreground="Black" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            <Button Style="{StaticResource SidebarButton}" Click="Scheduling_Click">
                    <StackPanel Orientation="Horizontal">
                    <Image Source="pack://application:,,,/YourMusicDepotApp;component/Icons/scheduling.png" Width="48" Height="48"/>
                    <TextBlock Text="Scheduling" Foreground="Black" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            <Button Style="{StaticResource SidebarButton}" Click="Finance_Click">
                <StackPanel Orientation="Horizontal">
                    <Image Source="pack://application:,,,/YourMusicDepotApp;component/Icons/finance.png" Width="48" Height="48"/>
                    <TextBlock Text="Finance" Foreground="Black" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </UniformGrid>

       
        <!-- Main content area -->
        <StackPanel x:Name="LogoStackPanel" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" >
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Image Source="pack://application:,,,/YourMusicDepotApp;component/Icons/CompanyLogo.png" Width="300" Height="300"/>
            </StackPanel>
        </StackPanel>


        
        <Frame Grid.Column="1" x:Name="MainContentFrame" 
           HorizontalAlignment="Stretch" 
           VerticalAlignment="Stretch" 
           ContentRendered="MainContentFrame_ContentRendered"/>
    </Grid>
</Window>
