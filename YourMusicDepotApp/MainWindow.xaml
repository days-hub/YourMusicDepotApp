<Window x:Class="YourMusicDepotApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
        Icon="pack://application:,,,/YourMusicDepotApp;component/Icons/YTreble.png"
        xmlns:views="clr-namespace:YourMusicDepotApp.Views"
        Title="YourMusicDepot" Height="1050" Width="1300"
        MinHeight="800" MinWidth="1150"
        Background="{DynamicResource MaterialDesignPaper}"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        FontFamily="{md:MaterialDesignFont}">

    <Window.Resources>
        <!-- Navigation rail item: icon over label, highlight when checked -->
        <Style x:Key="NavRailItem" TargetType="RadioButton">
            <Setter Property="Foreground" Value="#B4AECB"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="ItemBorder"
                                Background="Transparent"
                                CornerRadius="10"
                                Margin="10,4"
                                Padding="0,10">
                            <ContentPresenter HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#3A3153"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#4A3F6B"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="NavRailLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="92"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Navigation rail -->
        <Border Grid.Column="0" Background="#2D2640">
            <DockPanel LastChildFill="False">
                <md:PackIcon DockPanel.Dock="Top" Kind="MusicClefTreble"
                             Width="34" Height="34"
                             Foreground="White"
                             HorizontalAlignment="Center"
                             Margin="0,18,0,22"/>

                <RadioButton DockPanel.Dock="Top" x:Name="HomeNavItem" Style="{StaticResource NavRailItem}"
                             GroupName="Nav" Checked="Home_Click" IsChecked="True">
                    <StackPanel>
                        <md:PackIcon Kind="Home" Width="26" Height="26" HorizontalAlignment="Center"/>
                        <TextBlock Text="Home" Style="{StaticResource NavRailLabel}"/>
                    </StackPanel>
                </RadioButton>

                <RadioButton DockPanel.Dock="Top" Style="{StaticResource NavRailItem}"
                             GroupName="Nav" Checked="Instructors_Click">
                    <StackPanel>
                        <md:PackIcon Kind="HumanMaleBoard" Width="26" Height="26" HorizontalAlignment="Center"/>
                        <TextBlock Text="Instructors" Style="{StaticResource NavRailLabel}"/>
                    </StackPanel>
                </RadioButton>

                <RadioButton DockPanel.Dock="Top" Style="{StaticResource NavRailItem}"
                             GroupName="Nav" Checked="Students_Click">
                    <StackPanel>
                        <md:PackIcon Kind="School" Width="26" Height="26" HorizontalAlignment="Center"/>
                        <TextBlock Text="Students" Style="{StaticResource NavRailLabel}"/>
                    </StackPanel>
                </RadioButton>

                <RadioButton DockPanel.Dock="Top" Style="{StaticResource NavRailItem}"
                             GroupName="Nav" Checked="Scheduling_Click">
                    <StackPanel>
                        <md:PackIcon Kind="CalendarMonth" Width="26" Height="26" HorizontalAlignment="Center"/>
                        <TextBlock Text="Scheduling" Style="{StaticResource NavRailLabel}"/>
                    </StackPanel>
                </RadioButton>

                <RadioButton DockPanel.Dock="Top" Style="{StaticResource NavRailItem}"
                             GroupName="Nav" Checked="Finance_Click">
                    <StackPanel>
                        <md:PackIcon Kind="Finance" Width="26" Height="26" HorizontalAlignment="Center"/>
                        <TextBlock Text="Finance" Style="{StaticResource NavRailLabel}"/>
                    </StackPanel>
                </RadioButton>
            </DockPanel>
        </Border>

        <!-- Main content area -->
        <Frame Grid.Column="1" x:Name="MainContentFrame"
               HorizontalAlignment="Stretch"
               VerticalAlignment="Stretch"
               NavigationUIVisibility="Hidden"
               Source="Views/HomeView.xaml"/>
    </Grid>
</Window>
