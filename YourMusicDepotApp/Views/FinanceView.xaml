<UserControl x:Class="YourMusicDepotApp.Views.FinanceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">

    <Grid>
        <TabControl>
            <!-- Tab for Payment Details -->
            <TabItem Header="Payment Details">
                <Grid>
                    <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- Row for Title and Search Bar -->
                    <RowDefinition Height="Auto"/>
                    <!-- Fixed height row for Calendar -->
                    <RowDefinition Height="*"/>
                    <!-- Remaining space for DataGrid -->
                    <RowDefinition Height="Auto"/>
                    <!-- Row for Action Buttons --> 
                </Grid.RowDefinitions>
        <!-- Search Bar and Buttons -->

        <DockPanel Grid.Row="0" Margin="16,16,16,0">
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                <md:PackIcon Kind="Finance" Width="30" Height="30"
                             VerticalAlignment="Center"
                             Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                <TextBlock Text="Finance" FontSize="24" FontWeight="Medium"
                           Margin="10,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBox Width="260" VerticalAlignment="Center"
                         md:HintAssist.Hint="Search by date or student"
                         md:TextFieldAssist.HasClearButton="True"
                         Style="{StaticResource MaterialDesignTextBox}"
                         Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"/>
                <Button Content="Search" Command="{Binding SearchDateOrStudentCommand}" Margin="12,0,0,0"/>
            </StackPanel>
        </DockPanel>

        <!-- Data Grid for Music Lesson Payments -->
        <DataGrid x:Name="PaymentsDataGrid" Grid.Row="2" AutoGenerateColumns="False" ItemsSource="{Binding Payments}"
                  SelectedItem="{Binding SelectedPayment, Mode=TwoWay}" IsReadOnly="True" Margin="16">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Date" Binding="{Binding MusicLessonPaymentDate, StringFormat='{}{0:d}'}"/>
                <DataGridTextColumn Header="Amount" Binding="{Binding MusicLessonPaymentAmount, StringFormat='{}{0:C}'}"/>
                <DataGridTextColumn Header="Type" Binding="{Binding MusicLessonPaymentType}"/>
                <DataGridTextColumn Header="Student" Binding="{Binding MusicLesson.Student.FullName}"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="16,0,16,16">
            <Button Content="Add Payment" Command="{Binding AddPaymentCommand}" Margin="5"/>
            <Button Content="Edit Payment" Command="{Binding EditPaymentCommand}"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    IsEnabled="{Binding IsEditEnabled}" Margin="5"/>
            <Button Content="Delete Payment" Command="{Binding DeletePaymentCommand}"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    Foreground="#D32F2F" BorderBrush="#D32F2F" Margin="5"/>
        </StackPanel>
        </Grid>
    </TabItem>

            <!-- Tab for Revenue Over Time Graph -->
            <TabItem Header="Revenue Over Time">
                <Grid>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
           
                        </Grid.RowDefinitions>
                        <StackPanel VerticalAlignment="Top" Orientation="Horizontal" Grid.Row="0">
                            <TextBlock Text="Start Date:" VerticalAlignment="Center" Margin="5,0,0,0"/>
                            <DatePicker Margin="5" SelectedDate="{Binding StartDate}"/>

                            <!-- Label for the End Date DatePicker -->
                            <TextBlock Text="End Date:" VerticalAlignment="Center" Margin="10,0,0,0"/>
                            <DatePicker Margin="5" SelectedDate="{Binding EndDate}"/>
                            <Button Content="Show Revenue" Command="{Binding ShowRevenueCommand}" Margin="5"/>
                        </StackPanel>

                        <!-- Line Graph for Revenue Over Time -->
                        <lvc:CartesianChart Margin="5" Grid.Row="1">
                            <!-- Define the X Axis -->
                            <lvc:CartesianChart.AxisX>
                                <lvc:Axis Title="Time" Labels="{Binding RevenueDateLabels}">
                                </lvc:Axis>
                            </lvc:CartesianChart.AxisX>

                            <!-- Define the Y Axis -->
                            <lvc:CartesianChart.AxisY>
                                <lvc:Axis Title="Revenue">
                                 
                                </lvc:Axis>
                            </lvc:CartesianChart.AxisY>

                            <!-- Series -->
                            <lvc:CartesianChart.Series>
                                <lvc:LineSeries Title="Revenue" Values="{Binding RevenueValues}"/>
                            </lvc:CartesianChart.Series>
                        </lvc:CartesianChart>
                    </Grid>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</UserControl>
