<UserControl x:Class="YourMusicDepotApp.Views.FinanceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">

    <Grid>
        <TabControl>
            <!-- Tab for Payment Details -->
            <TabItem Header="Payment Details">
                <Grid>
                    <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- Row for Title and Search Bar -->
                    <RowDefinition Height="Auto"/>
                    <!-- Fixed height row for Calendar -->
                    <RowDefinition Height="*"/>
                    <!-- Remaining space for DataGrid -->
                    <RowDefinition Height="Auto"/>
                    <!-- Row for Action Buttons --> 
                </Grid.RowDefinitions>
        <!-- Search Bar and Buttons -->

        <StackPanel Grid.Row="0" VerticalAlignment="Top" HorizontalAlignment="Center">
            <StackPanel Orientation="Horizontal">
                <Image Source="pack://application:,,,/YourMusicDepotApp;component/Icons/finance.png" Width="24" Height="24" Margin="10,10,5,10"/>
                <TextBlock Text="Finance" FontWeight="Bold" FontSize="24" Margin="0,10"/>
            </StackPanel>
        </StackPanel>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Grid.Row="1">
            <Image Source="pack://application:,,,/YourMusicDepotApp;component/Icons/Search.png" Width="24" Height="24" Margin="10,10,5,10"/>
                 <TextBox Margin="10,10,5,10" Width="200" Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"/>
                 <Button Content="Search" Command="{Binding SearchDateOrStudentCommand}" Margin="0,10"/>
            </StackPanel>
        <!-- Data Grid for Music Lesson Payments -->
                    <!-- Data Grid for Music Lesson Payments -->
                    <DataGrid x:Name="PaymentsDataGrid" Grid.Row="2" AutoGenerateColumns="False" ItemsSource="{Binding Payments}"
          SelectedItem="{Binding SelectedPayment, Mode=TwoWay}" IsReadOnly="True">
                        <DataGrid.Columns>
                <DataGridTextColumn Header="Date" Binding="{Binding MusicLessonPaymentDate}"/>
                <DataGridTextColumn Header="Amount" Binding="{Binding MusicLessonPaymentAmount}"/>
                <DataGridTextColumn Header="Type" Binding="{Binding MusicLessonPaymentType}"/>
                <DataGridTextColumn Header="Student" Binding="{Binding MusicLesson.Student.FullName}"/>
            </DataGrid.Columns>
        </DataGrid>
        
        <StackPanel Grid.Row="3" Orientation="Horizontal">
            <TextBox x:Name="SearchBox" Width="200" Margin="5"/>
            <Button Content="Add Payment" Command="{Binding AddPaymentCommand}" Margin="5"/>
                        <Button Content="Edit Payment" Command="{Binding EditPaymentCommand}" 
        IsEnabled="{Binding IsEditEnabled}" Margin="5"/>
                        <Button Content="Delete Payment" Command="{Binding DeletePaymentCommand}" Margin="5"/>
        </StackPanel>
        </Grid>
    </TabItem>

            <!-- Tab for Revenue Over Time Graph -->
            <TabItem Header="Revenue Over Time">
                <Grid>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
           
                        </Grid.RowDefinitions>
                        <StackPanel VerticalAlignment="Top" Orientation="Horizontal" Grid.Row="0">
                            <TextBlock Text="Start Date:" VerticalAlignment="Center" Margin="5,0,0,0"/>
                            <DatePicker Margin="5" SelectedDate="{Binding StartDate}"/>

                            <!-- Label for the End Date DatePicker -->
                            <TextBlock Text="End Date:" VerticalAlignment="Center" Margin="10,0,0,0"/>
                            <DatePicker Margin="5" SelectedDate="{Binding EndDate}"/>
                            <Button Content="Show Revenue" Command="{Binding ShowRevenueCommand}" Margin="5"/>
                        </StackPanel>

                        <!-- Line Graph for Revenue Over Time -->
                        <lvc:CartesianChart Margin="5" Grid.Row="1">
                            <!-- Define the X Axis -->
                            <lvc:CartesianChart.AxisX>
                                <lvc:Axis Title="Time" Labels="{Binding RevenueDateLabels}">
                                </lvc:Axis>
                            </lvc:CartesianChart.AxisX>

                            <!-- Define the Y Axis -->
                            <lvc:CartesianChart.AxisY>
                                <lvc:Axis Title="Revenue">
                                 
                                </lvc:Axis>
                            </lvc:CartesianChart.AxisY>

                            <!-- Series -->
                            <lvc:CartesianChart.Series>
                                <lvc:LineSeries Title="Revenue" Values="{Binding RevenueValues}"/>
                            </lvc:CartesianChart.Series>
                        </lvc:CartesianChart>
                    </Grid>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</UserControl>
