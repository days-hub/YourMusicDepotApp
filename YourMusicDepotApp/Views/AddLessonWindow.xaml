<Window x:Class="YourMusicDepotApp.Views.AddLessonWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        Icon="pack://application:,,,/YourMusicDepotApp;component/Icons/YourMusicNoteIcon.png"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add New Lesson" Height="650" Width="800">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Text="Add New Lesson" FontSize="20" FontWeight="Bold" Margin="5" HorizontalAlignment="Center"/>

        <!-- Form for Adding New Lesson -->
        <StackPanel Grid.Row="1" Margin="5">
            <!-- Instructor Dropdown -->
            <TextBlock Text="Instructor:" Margin="5"/>
            <ComboBox ItemsSource="{Binding Instructors}" DisplayMemberPath="FullName" SelectedItem="{Binding NewLesson.Instructor, Mode=TwoWay}" Margin="5" />

            <!-- Student Dropdown -->
            <TextBlock Text="Student:" Margin="5"/>
            <ComboBox ItemsSource="{Binding Students}" DisplayMemberPath="FullName" SelectedItem="{Binding NewLesson.Student, Mode=TwoWay}" Margin="5" />

            <!-- Room Dropdown -->
            <TextBlock Text="Room:" Margin="5"/>
            <ComboBox ItemsSource="{Binding Rooms}" DisplayMemberPath="RoomID" SelectedItem="{Binding NewLesson.Room, Mode=TwoWay}" Margin="5" />

            <!-- Lesson Status Dropdown -->
            <TextBlock Text="Lesson Status:" Margin="5"/>
            <ComboBox ItemsSource="{Binding StatusChoices}" SelectedItem="{Binding NewLesson.MusicLessonStatus, Mode=TwoWay}" Margin="5" />

            <!-- Start Date Picker -->
            <TextBlock Text="Start Date:" Margin="5"/>
            <DatePicker SelectedDate="{Binding NewLesson.MusicLessonStartDateTime, Mode=TwoWay}" Margin="5" />

            <!-- Start Time Picker (ComboBox) -->
            <TextBlock Text="Start Time:" Margin="5"/>
            <ComboBox SelectedItem="{Binding SelectedStartTime, Mode=TwoWay}" ItemsSource="{Binding TimeOptions}" Margin="5" />

            <!-- End Date Picker -->
            <TextBlock Text="End Date:" Margin="5"/>
            <DatePicker SelectedDate="{Binding NewLesson.MusicLessonEndDateTime, Mode=TwoWay}" Margin="5" />

            <!-- End Time Picker (ComboBox) -->
            <TextBlock Text="End Time:" Margin="5"/>
            <ComboBox SelectedItem="{Binding SelectedEndTime, Mode=TwoWay}" ItemsSource="{Binding TimeOptions}" Margin="5" />
        </StackPanel>

        <!-- Buttons for Saving or Canceling -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="10">
            <Button Content="Save" Command="{Binding SaveNewLessonCommand}" Margin="5"/>
            <Button Content="Cancel" Command="{Binding CloseWindowCommand}" Margin="5"/>
        </StackPanel>
    </Grid>
</Window>
