<Window x:Class="YourMusicDepotApp.Views.EditLessonWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        Icon="pack://application:,,,/YourMusicDepotApp;component/Icons/YourMusicNoteIcon.png"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:YourMusicDepotApp.Converters"
        Title="Edit Lesson" Height="550" Width="800">
    <Window.Resources>
        <converters:TimeConverter x:Key="TimeConverter"/>
    </Window.Resources>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Text="Edit Lesson" FontSize="20" FontWeight="Bold" Margin="5" HorizontalAlignment="Center"/>

        <!-- Form for Editing Lesson -->
        <StackPanel Grid.Row="1" Margin="5">
            <!-- Instructor Dropdown -->
            <TextBlock Text="Instructor:" Margin="3"/>
            <ComboBox ItemsSource="{Binding Instructors}" DisplayMemberPath="FullName" 
                      SelectedValue="{Binding SelectedMusicLesson.InstructorID, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                      SelectedValuePath="InstructorID"/>

            <!-- Student Dropdown -->
            <TextBlock Text="Student:" Margin="3"/>
            <ComboBox ItemsSource="{Binding Students}" DisplayMemberPath="FullName" 
                      SelectedValue="{Binding SelectedMusicLesson.StudentID, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                      SelectedValuePath="StudentID"/>

            <!-- Room Dropdown -->
            <TextBlock Text="Room:" Margin="3"/>
            <ComboBox ItemsSource="{Binding Rooms}" DisplayMemberPath="RoomID" 
                      SelectedValue="{Binding SelectedMusicLesson.RoomID, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                      SelectedValuePath="RoomID"/>

            <!-- Status Dropdown -->
            <TextBlock Text="Status:" Margin="3"/>
            <ComboBox ItemsSource="{Binding StatusChoices}" 
                      SelectedItem="{Binding SelectedMusicLesson.MusicLessonStatus, Mode=TwoWay}"/>

            <!-- Start Date Picker -->
            <TextBlock Text="Start Date:" Margin="3"/>
            <DatePicker SelectedDate="{Binding SelectedMusicLesson.MusicLessonStartDateTime, Mode=TwoWay}"/>

            <!-- Start Time Dropdown -->
            <TextBlock Text="Start Time:" Margin="3"/>
            <ComboBox ItemsSource="{Binding TimeOptions}" 
                      SelectedItem="{Binding StartTime, Mode=TwoWay}"/>

            <!-- End Date Picker -->
            <TextBlock Text="End Date:" Margin="3"/>
            <DatePicker SelectedDate="{Binding SelectedMusicLesson.MusicLessonEndDateTime, Mode=TwoWay}"/>

            <!-- End Time Dropdown -->
            <TextBlock Text="End Time:" Margin="3"/>
            <ComboBox ItemsSource="{Binding TimeOptions}" 
                      SelectedItem="{Binding EndTime, Mode=TwoWay}"/>
        </StackPanel>

        <!-- Buttons for Saving or Canceling -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="10">
            <Button Content="Save" Command="{Binding SaveLessonChangesCommand}" Margin="5"/>
            <Button Content="Cancel" Command="{Binding CloseWindowCommand}" Margin="5"/>
        </StackPanel>
    </Grid>
</Window>
