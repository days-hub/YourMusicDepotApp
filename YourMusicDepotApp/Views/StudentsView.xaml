<UserControl x:Class="YourMusicDepotApp.Views.StudentsView"
             xmlns:vm="clr-namespace:YourMusicDepotApp.ViewModels"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="1000">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <!-- Sidebar for Add and List -->
            <ColumnDefinition Width="*"/>
            <!-- Detail View -->
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Title and Search Bar -->
            <RowDefinition Height="*"/>
            <!-- List and Detail View -->
        </Grid.RowDefinitions>

        <!-- Title and Search Bar with Icons -->
        <StackPanel Grid.ColumnSpan="2" Grid.Row="0" Orientation="Vertical" HorizontalAlignment="Center">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,10">
                <Image Source="pack://application:,,,/YourMusicDepotApp;component/Icons/students.png" Width="50" Height="50" Margin="0,0,5,0"/>
                <TextBlock Text="Students"
                   FontWeight="Bold"
                   FontSize="24"
                   Foreground="Black"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
                <Image Source="pack://application:,,,/YourMusicDepotApp;component/Icons/Search.png" Width="35" Height="35" Margin="0,0,5,0"/>
                <TextBox Width="200"
                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>
        </StackPanel>


        <!-- Add Student Button and Students List -->
        <StackPanel Grid.Column="0" Grid.Row="1">
            <Button Command="{Binding OpenAddStudentWindowCommand}"
                    Content="Add Student"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,10"/>
            <Border Grid.Column="0" Grid.Row="1" BorderBrush="Gray" BorderThickness="1" CornerRadius="5" Margin="5">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ListBox ItemsSource="{Binding Students}"
          SelectedItem="{Binding SelectedStudent}"
         Margin="0" Padding="0" Style="{StaticResource MaterialDesignListBox}">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="10"/>
                        <Setter Property="Margin" Value="5"/>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding StudentFirstName}" FontWeight="Bold" FontSize="16" Margin="5,0"/>
                                <TextBlock Text="{Binding StudentLastName}" FontWeight="Bold" FontSize="16" Margin="5,0"/>
                      
                            </StackPanel>
                        
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
            </ScrollViewer>
            </Border>
        </StackPanel>

        <!-- Student Detail View -->
        <md:Card Grid.Row="1" Grid.Column="1"
          Background="#27F1C1"
          Margin="16" Padding="16" 
          md:ShadowAssist.ShadowDepth="Depth2">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- For Image -->
                    <RowDefinition Height="Auto"/>
                    <!-- For Name -->
                    <RowDefinition Height="Auto"/>
                    <!-- For Last Instructor -->
                    <RowDefinition Height="Auto"/>
                    <!-- For Instrument -->
                    <RowDefinition Height="Auto"/>
                    <!-- For Skill Level -->
                    <RowDefinition Height="Auto"/>
                    <!-- For Phone -->
                    <RowDefinition Height="Auto"/>
                    <!-- For Email -->
                    <RowDefinition Height="Auto"/>

                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Student Detailed View"
                   FontWeight="Bold"
                   FontSize="18"
                   HorizontalAlignment="Left" 
                   Margin="0,0,0,10"/>
                <Image Grid.Row="1" Source="{Binding SelectedStudent.ProfilePicturePath}"
               Width="200"
               Height="200"
               HorizontalAlignment="Center"
               Margin="0,10,0,10"/>

                <!-- Student Name with Icon -->
                <StackPanel Grid.Row="3" Grid.Column="0" Orientation="Horizontal" Margin="45" HorizontalAlignment="Left">
                    <Image Source="pack://application:,,,/YourMusicDepotApp;component/Icons/NameIcon.png" Width="32" Height="32"/>
                    <TextBlock Text="Name: " FontWeight="Bold" FontSize="16" Margin="5,0"/>
                    <TextBlock Text="{Binding SelectedStudent.FullName}" FontSize="16"/>
                </StackPanel>

                <!-- Last Instructor with Icon -->
                <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" Margin="45" HorizontalAlignment="Right">
                    <Image Source="pack://application:,,,/YourMusicDepotApp;component/Icons/instructors.png" Width="32" Height="32"/>
                    <TextBlock Text="Last Instructor: " FontWeight="Bold" FontSize="16" Margin="5,0"/>
                    <TextBlock Text="{Binding SelectedStudent.LastInstructorName}" FontSize="14"/>
                </StackPanel>

                <!-- Student Instrument with Icon -->
                <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="45" HorizontalAlignment="Left" >
                    <Image Source="pack://application:,,,/YourMusicDepotApp;component/Icons/Instrument.png" Width="32" Height="32"/>
                    <TextBlock Text="Instrument: " FontWeight="Bold" FontSize="16" Margin="5,0"/>
                    <TextBlock Text="{Binding SelectedStudent.FirstMusicProgress.StudentInstrument}" FontSize="16"/>
                </StackPanel>

                <!-- Student Skill Level with Icon -->
                <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="45" HorizontalAlignment="Right">
                    <Image Source="pack://application:,,,/YourMusicDepotApp;component/Icons/Skill.png" Width="32" Height="32"/>
                    <TextBlock Text="Skill Level: " FontWeight="Bold" FontSize="16" Margin="5,0"/>
                    <TextBlock Text="{Binding SelectedStudent.FirstMusicProgress.StudentSkillLevel}" FontSize="16"/>
                </StackPanel>

                <!-- Student Phone Number with Icon -->
                <StackPanel Grid.Row="7" Orientation="Horizontal" Margin="45" HorizontalAlignment="Left">
                    <Image Source="pack://application:,,,/YourMusicDepotApp;component/Icons/PhoneIcon.png" Width="32" Height="32"/>
                    <TextBlock Text="Phone: " FontWeight="Bold" FontSize="16" Margin="5,0"/>
                    <TextBlock Text="{Binding SelectedStudent.StudentPhoneNumber}" FontSize="16"/>
                </StackPanel>

                <!-- Student Email with Icon -->
                <StackPanel Grid.Row="7" Orientation="Horizontal" Margin="45" HorizontalAlignment="Right">
                    <Image Source="pack://application:,,,/YourMusicDepotApp;component/Icons/EmailIcon.png" Width="16" Height="16"/>
                    <TextBlock Text="Email: " FontWeight="Bold" FontSize="16" Margin="5,0"/>
                    <TextBlock Text="{Binding SelectedStudent.StudentEmail}" FontSize="16"/>
                </StackPanel>

                <!-- Edit, Delete, View Schedule Buttons -->
                <StackPanel Grid.Row="9" Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="20,10,20,10">
                    <Button Command="{Binding EditStudentCommand}" Content="Edit" Margin="5" />
                    <Button Command="{Binding DeleteStudentCommand}" Content="Delete" Margin="5" />
                </StackPanel>
            </Grid>
        </md:Card>
    </Grid>
</UserControl>
