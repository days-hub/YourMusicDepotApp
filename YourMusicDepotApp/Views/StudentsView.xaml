<UserControl x:Class="YourMusicDepotApp.Views.StudentsView"
             xmlns:vm="clr-namespace:YourMusicDepotApp.ViewModels"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="900" d:DesignWidth="1200">

    <UserControl.Resources>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBodyLight}"/>
        </Style>
        <Style x:Key="FieldValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Margin" Value="0,2,0,0"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
        <Style x:Key="FieldIcon" TargetType="md:PackIcon">
            <Setter Property="Width" Value="22"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="Margin" Value="0,2,12,0"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryHueMidBrush}"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="24,16,24,24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Page header: title left, search right -->
        <DockPanel Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,16">
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                <md:PackIcon Kind="School" Width="30" Height="30"
                             VerticalAlignment="Center"
                             Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                <TextBlock Text="Students" FontSize="24" FontWeight="Medium"
                           Margin="10,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>
            <TextBox DockPanel.Dock="Right" HorizontalAlignment="Right"
                     Width="260" VerticalAlignment="Center"
                     md:HintAssist.Hint="Search students"
                     md:TextFieldAssist.HasClearButton="True"
                     Style="{StaticResource MaterialDesignTextBox}"
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
        </DockPanel>

        <!-- Student list -->
        <md:Card Grid.Row="1" Grid.Column="0" Padding="12" Margin="0,0,16,0"
                 md:ShadowAssist.ShadowDepth="Depth1">
            <DockPanel>
                <Button DockPanel.Dock="Top"
                        Command="{Binding OpenAddStudentWindowCommand}"
                        Content="Add Student"
                        HorizontalAlignment="Stretch"
                        Margin="0,0,0,12"/>
                <ListBox ItemsSource="{Binding Students}"
                         SelectedItem="{Binding SelectedStudent}"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         Style="{StaticResource MaterialDesignListBox}">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="12,10"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding FullName}" FontSize="14"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </md:Card>

        <!-- Student detail -->
        <md:Card Grid.Row="1" Grid.Column="1" Padding="32"
                 md:ShadowAssist.ShadowDepth="Depth1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- Profile header -->
                    <RowDefinition Height="Auto"/>
                    <!-- Divider -->
                    <RowDefinition Height="Auto"/>
                    <!-- Info grid -->
                    <RowDefinition Height="*"/>
                    <!-- Spacer -->
                    <RowDefinition Height="Auto"/>
                    <!-- Buttons -->
                </Grid.RowDefinitions>

                <!-- Profile header: avatar + name + instrument -->
                <StackPanel Grid.Row="0" Orientation="Horizontal">
                    <Image Width="96" Height="96"
                           Source="{Binding SelectedStudent.ProfilePicturePath, TargetNullValue='pack://application:,,,/YourMusicDepotApp;component/Icons/avatar-placeholder.png', FallbackValue='pack://application:,,,/YourMusicDepotApp;component/Icons/avatar-placeholder.png'}"/>
                    <StackPanel VerticalAlignment="Center" Margin="24,0,0,0">
                        <TextBlock Text="{Binding SelectedStudent.FullName, FallbackValue='Select a student'}"
                                   FontSize="24" FontWeight="Medium"/>
                        <TextBlock Text="{Binding SelectedStudent.FirstMusicProgress.StudentInstrument}"
                                   FontSize="14"
                                   Foreground="{DynamicResource MaterialDesignBodyLight}"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </StackPanel>

                <Separator Grid.Row="1" Margin="0,24" Style="{StaticResource MaterialDesignSeparator}"/>

                <!-- Info grid: 2 columns of labeled fields -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Skill level -->
                    <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Margin="0,0,24,28">
                        <md:PackIcon Kind="ChartBar" Style="{StaticResource FieldIcon}"/>
                        <StackPanel>
                            <TextBlock Text="Skill Level" Style="{StaticResource FieldLabel}"/>
                            <TextBlock Text="{Binding SelectedStudent.FirstMusicProgress.StudentSkillLevel}" Style="{StaticResource FieldValue}"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Last instructor -->
                    <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,28">
                        <md:PackIcon Kind="HumanMaleBoard" Style="{StaticResource FieldIcon}"/>
                        <StackPanel>
                            <TextBlock Text="Last Instructor" Style="{StaticResource FieldLabel}"/>
                            <TextBlock Text="{Binding SelectedStudent.LastInstructorName}" Style="{StaticResource FieldValue}"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Phone -->
                    <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" Margin="0,0,24,0">
                        <md:PackIcon Kind="Phone" Style="{StaticResource FieldIcon}"/>
                        <StackPanel>
                            <TextBlock Text="Phone" Style="{StaticResource FieldLabel}"/>
                            <TextBlock Text="{Binding SelectedStudent.StudentPhoneNumber}" Style="{StaticResource FieldValue}"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Email -->
                    <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal">
                        <md:PackIcon Kind="Email" Style="{StaticResource FieldIcon}"/>
                        <StackPanel>
                            <TextBlock Text="Email" Style="{StaticResource FieldLabel}"/>
                            <TextBlock Text="{Binding SelectedStudent.StudentEmail}" Style="{StaticResource FieldValue}"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <!-- Actions -->
                <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Command="{Binding EditStudentCommand}"
                            Content="Edit"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Margin="0,0,8,0"/>
                    <Button Command="{Binding DeleteStudentCommand}"
                            Content="Delete"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Foreground="#D32F2F"
                            BorderBrush="#D32F2F"/>
                </StackPanel>
            </Grid>
        </md:Card>
    </Grid>
</UserControl>
