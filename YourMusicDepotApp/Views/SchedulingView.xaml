<UserControl x:Class="YourMusicDepotApp.Views.SchedulingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:controls="clr-namespace:YourMusicDepotApp.Controls"
             xmlns:converters="clr-namespace:YourMusicDepotApp.Converters"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">

    <UserControl.Resources>
        <converters:RoomCapacityCountConverter x:Key="RoomCapacityCountConverter"/>
        <converters:RoomCapacityConverter x:Key="RoomCapacityConverter"/>
        <converters:DateHasLessonsConverter x:Key="DateHasLessonsConverter"/>
        <converters:LessonStatusToBrushConverter x:Key="LessonStatusToBrushConverter"/>

        <!-- Month/year buttons in the calendar's zoomed-out views, enlarged to
             match the bigger day grid -->
        <Style x:Key="LargeCalendarButtonStyle" TargetType="CalendarButton"
               BasedOn="{StaticResource MaterialDesignCalendarButton}">
            <Setter Property="Width" Value="91"/>
            <Setter Property="Height" Value="64"/>
            <Setter Property="FontSize" Value="15"/>
        </Style>

        <!-- Enlarged day cells (sized here rather than via a ScaleTransform,
             which rasterizes and blurs the calendar) with an indicator dot
             under dates that have lessons -->
        <Style x:Key="LessonDayButtonStyle" TargetType="CalendarDayButton"
               BasedOn="{StaticResource MaterialDesignCalendarDayButton}">
            <Setter Property="Width" Value="52"/>
            <Setter Property="Height" Value="46"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="ContentTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <!-- Inherits the day button's FontSize; the calendar
                                 header's large font must not leak in here -->
                            <TextBlock Text="{Binding}" HorizontalAlignment="Center"/>
                            <!-- Hidden (not Collapsed) when there are no lessons so
                                 every day number sits at the same height -->
                            <Ellipse Width="5" Height="5"
                                     Fill="{DynamicResource PrimaryHueMidBrush}"
                                     HorizontalAlignment="Center"
                                     Margin="0,3,0,0">
                                <Ellipse.Visibility>
                                    <MultiBinding Converter="{StaticResource DateHasLessonsConverter}">
                                        <Binding Path="DataContext" RelativeSource="{RelativeSource AncestorType=CalendarDayButton}"/>
                                        <Binding Path="DataContext.LessonDates" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                    </MultiBinding>
                                </Ellipse.Visibility>
                            </Ellipse>
                        </StackPanel>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Row for Title -->
            <RowDefinition Height="*"/>
            <!-- Tabs fill the remaining space -->
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="16,16,16,8">
            <md:PackIcon Kind="CalendarMonth" Width="30" Height="30"
                         VerticalAlignment="Center"
                         Foreground="{DynamicResource PrimaryHueMidBrush}"/>
            <TextBlock Text="Scheduling" FontSize="24" FontWeight="Medium"
                       Margin="10,0,0,0" VerticalAlignment="Center"/>
        </StackPanel>

        <TabControl Grid.Row="1">
            <TabItem Header="Scheduling">
                <Grid Margin="16">
                    <Grid.ColumnDefinitions>
                        <!-- Large calendar on the left, selected day's lessons on the right -->
                        <ColumnDefinition Width="5*"/>
                        <ColumnDefinition Width="4*"/>
                    </Grid.ColumnDefinitions>

                    <Calendar x:Name="MaterialCalendar" Grid.Column="0"
                              Style="{StaticResource MaterialDesignCalendarPortrait}"
                              CalendarDayButtonStyle="{StaticResource LessonDayButtonStyle}"
                              CalendarButtonStyle="{StaticResource LargeCalendarButtonStyle}"
                              SelectedDatesChanged="Calendar_SelectedDatesChanged"
                              HorizontalAlignment="Center" VerticalAlignment="Top"
                              Margin="0,0,16,0"/>

                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <!-- Search -->
                            <RowDefinition Height="Auto"/>
                            <!-- Day header -->
                            <RowDefinition Height="*"/>
                            <!-- Lesson list -->
                            <RowDefinition Height="Auto"/>
                            <!-- Action buttons -->
                        </Grid.RowDefinitions>

                        <DockPanel Grid.Row="0" Margin="0,0,0,12">
                            <Button DockPanel.Dock="Right" Content="Search"
                                    Command="{Binding SearchDateCommand}"
                                    Margin="8,0,0,0" VerticalAlignment="Center"/>
                            <TextBox md:HintAssist.Hint="Jump to a date (e.g. 7/16/2026)"
                                     md:TextFieldAssist.HasClearButton="True"
                                     Style="{StaticResource MaterialDesignTextBox}"
                                     VerticalAlignment="Center"
                                     Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"/>
                        </DockPanel>

                        <StackPanel Grid.Row="1" Margin="0,0,0,8">
                            <TextBlock FontSize="18" FontWeight="Medium"
                                       Text="{Binding SelectedDate, StringFormat='{}{0:dddd, MMMM d}'}"/>
                            <TextBlock FontSize="12" Foreground="#757575">
                                <Run Text="{Binding MusicLessons.Count, Mode=OneWay}"/><Run Text=" lesson(s)"/>
                            </TextBlock>
                        </StackPanel>

                        <ListBox Grid.Row="2"
                                 ItemsSource="{Binding MusicLessons}"
                                 SelectedItem="{Binding SelectedMusicLesson, Mode=TwoWay}"
                                 HorizontalContentAlignment="Stretch"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0,0,0,8"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1"
                                            CornerRadius="8" Padding="12,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0" Margin="0,0,14,0" VerticalAlignment="Center">
                                                <TextBlock FontSize="14" FontWeight="SemiBold"
                                                           Text="{Binding MusicLessonStartDateTime, StringFormat='{}{0:HH:mm}'}"/>
                                                <TextBlock FontSize="11" Foreground="#9E9E9E"
                                                           Text="{Binding MusicLessonEndDateTime, StringFormat='{}{0:HH:mm}'}"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock FontSize="13" FontWeight="SemiBold"
                                                           Text="{Binding Student.FullName}"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock FontSize="12" Foreground="#757575" TextTrimming="CharacterEllipsis">
                                                    <Run Text="{Binding Instructor.FullName, Mode=OneWay}"/><Run Text=" · Room "/><Run Text="{Binding Room.RoomID, Mode=OneWay}"/><Run Text=" · "/><Run>
                                                        <Run.Text>
                                                            <MultiBinding Converter="{StaticResource RoomCapacityConverter}" Mode="OneWay">
                                                                <Binding Path="Room.RoomSize" Mode="OneWay"/>
                                                                <Binding Path="CurrentRoomCapacityCount" Mode="OneWay"/>
                                                            </MultiBinding>
                                                        </Run.Text>
                                                    </Run>
                                                </TextBlock>
                                            </StackPanel>

                                            <Border Grid.Column="2" VerticalAlignment="Center"
                                                    CornerRadius="10" Padding="10,3"
                                                    Background="{Binding MusicLessonStatus, Converter={StaticResource LessonStatusToBrushConverter}, ConverterParameter=Fill}">
                                                <TextBlock FontSize="11" FontWeight="Medium"
                                                           Text="{Binding MusicLessonStatus}"
                                                           Foreground="{Binding MusicLessonStatus, Converter={StaticResource LessonStatusToBrushConverter}, ConverterParameter=Text}"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <TextBlock Grid.Row="2" Text="No lessons on this day"
                                   FontSize="13" Foreground="#9E9E9E"
                                   HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding MusicLessons.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                            <Button Content="Edit" Command="{Binding EditLessonCommand}" Margin="0,0,8,0"/>
                            <Button Content="Delete" Command="{Binding DeleteLessonCommand}" Margin="0,0,8,0"/>
                            <Button Content="Add Lesson" Command="{Binding AddLessonCommand}"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="Weekly Schedule" x:Name="WeeklyScheduleTab">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <!-- Toolbar: week navigation, search, legend -->
                        <RowDefinition Height="*"/>
                        <!-- Week view -->
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="0,0,0,12" LastChildFill="False">
                        <Button DockPanel.Dock="Left" Style="{StaticResource MaterialDesignToolButton}"
                                Command="{Binding PreviousWeekCommand}" ToolTip="Previous week">
                            <md:PackIcon Kind="ChevronLeft" Width="22" Height="22"/>
                        </Button>
                        <Button DockPanel.Dock="Left" Style="{StaticResource MaterialDesignToolButton}"
                                Command="{Binding NextWeekCommand}" ToolTip="Next week">
                            <md:PackIcon Kind="ChevronRight" Width="22" Height="22"/>
                        </Button>
                        <Button DockPanel.Dock="Left" Content="Today"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Command="{Binding GoToTodayCommand}" Margin="8,0,0,0"/>
                        <TextBlock DockPanel.Dock="Left" FontSize="16" FontWeight="Medium"
                                   VerticalAlignment="Center" Margin="16,0,0,0"
                                   Text="{Binding WeekRangeText}"/>

                        <!-- Legend chips use the shared lesson status palette -->
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Background="#E8F5E9" CornerRadius="10" Padding="10,3" Margin="4,0">
                                <TextBlock Text="Scheduled" FontSize="11" FontWeight="Medium" Foreground="#1B5E20"/>
                            </Border>
                            <Border Background="#E3F2FD" CornerRadius="10" Padding="10,3" Margin="4,0">
                                <TextBlock Text="Completed" FontSize="11" FontWeight="Medium" Foreground="#0D47A1"/>
                            </Border>
                            <Border Background="#FDECEA" CornerRadius="10" Padding="10,3" Margin="4,0">
                                <TextBlock Text="Canceled" FontSize="11" FontWeight="Medium" Foreground="#B71C1C"/>
                            </Border>
                        </StackPanel>

                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="0,0,16,0">
                            <TextBox Width="200" VerticalAlignment="Center"
                                     md:HintAssist.Hint="Search student or instructor"
                                     md:TextFieldAssist.HasClearButton="True"
                                     Style="{StaticResource MaterialDesignTextBox}"
                                     Text="{Binding WeeklyScheduleSearchQuery, UpdateSourceTrigger=PropertyChanged}"/>
                            <Button Style="{StaticResource MaterialDesignToolButton}"
                                    Command="{Binding SearchWeeklyScheduleCommand}" ToolTip="Search">
                                <md:PackIcon Kind="Magnify" Width="20" Height="20"/>
                            </Button>
                        </StackPanel>
                    </DockPanel>

                    <controls:WeekScheduleControl Grid.Row="1"
                                                  ItemsSource="{Binding ScheduleAppointments}"
                                                  WeekStart="{Binding CurrentWeekStart}"/>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
